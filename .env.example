# API keys for models you want to evaluate or judge with.
# Fill in only the providers you actually use; missing keys cause a clean error.
# Copy this file to `.env` and the eval pipeline will load it via python-dotenv.

# Used by the headline `gemini-3.1-pro-preview` judge and any Gemini models.
GEMINI_API_KEY=

# Used by gpt-5.x, o3, etc. (also for OpenAI-judge variants in robustness checks).
OPENAI_API_KEY=

# Used by Claude Opus / Sonnet baselines.
ANTHROPIC_API_KEY=

# Used by Grok 4.x baselines.
XAI_API_KEY=

# Used by DeepSeek V4 Pro / Flash baselines (also the DeepSeek judge variant).
DEEPSEEK_API_KEY=

# Used by Qwen models hosted on Alibaba Dashscope (e.g. Qwen3-Max).
DASHSCOPE_API_KEY=

# Used by Mistral direct API; or use OPENROUTER below to route via OpenRouter.
MISTRAL_API_KEY=

# Used to route models that don't have a direct SDK (e.g. mistral-medium-3.5).
OPENROUTER_API_KEY=

# Used by Moonshot Kimi baselines.
MOONSHOT_API_KEY=

# Used to download the released LoRA adapter (justinphan3110/Qwen3-14B_PCT).
# Only required if you pull the gated model or want higher rate limits.
HF_TOKEN=
